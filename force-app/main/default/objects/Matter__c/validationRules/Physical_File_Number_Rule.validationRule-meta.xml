<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Physical_File_Number_Rule</fullName>
    <active>true</active>
    <description>Physical file number needs to be filled for Old Matters</description>
    <errorConditionFormula>AND(
    ISPICKVAL(New_or_Old_Matter__c, &quot;Old&quot;),
    ISBLANK(Physical_File_Number__c)
)</errorConditionFormula>
    <errorDisplayField>Physical_File_Number__c</errorDisplayField>
    <errorMessage>Please fill in the Physical File Number</errorMessage>
</ValidationRule>
