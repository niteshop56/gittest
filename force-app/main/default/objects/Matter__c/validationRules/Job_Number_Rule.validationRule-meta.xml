<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Job_Number_Rule</fullName>
    <active>true</active>
    <description>Job Number need to be filled for Old Matters</description>
    <errorConditionFormula>AND(
    ISPICKVAL(New_or_Old_Matter__c, &quot;Old&quot;),
    ISBLANK(Job_No__c)
)</errorConditionFormula>
    <errorDisplayField>Job_No__c</errorDisplayField>
    <errorMessage>Please fill in the Job Number field</errorMessage>
</ValidationRule>
